# Frontend-only deployment
NODE_ENV=production

# Supabase browser client (safe to expose in the built frontend)
# Project: liuyao-v2 (ref: vnwhsdmcnkfavdmbxskc)
VITE_SUPABASE_URL=https://vnwhsdmcnkfavdmbxskc.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key_here

# Nginx container port mapping
CLIENT_HTTP_PORT=80

# GitHub Container Registry, only needed when using docker-compose.ghcr.yml
# GHCR_REGISTRY=ghcr.io
# GHCR_REPO=your-username/liuyao-divination
# IMAGE_TAG=latest

# Server-side secrets are configured in Supabase, not in this frontend .env:
# - SUPABASE_SERVICE_ROLE_KEY for the admin-api Edge Function
# - DEEPSEEK_API_KEY for the analyze-ai Edge Function fallback
