# Application environment
NODE_ENV=production

# Supabase Postgres
# Use the Supabase direct or transaction-pooler Postgres connection string.
# Project: liuyao-v2 (ref: vnwhsdmcnkfavdmbxskc)
# Replace <database-password> with the database password from Supabase Dashboard.
SUPABASE_DB_URL=postgresql://postgres.vnwhsdmcnkfavdmbxskc:<database-password>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_SSL=true
SUPABASE_DB_POOL_SIZE=10

# JWT
JWT_SECRET=your_jwt_secret_key_here_please_change
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Ports
SERVER_PORT=5000
CLIENT_HTTP_PORT=80
CLIENT_HTTPS_PORT=443

# GitHub Container Registry
# GHCR_REGISTRY=ghcr.io
# GHCR_REPO=your-username/liuyao-divination
# IMAGE_TAG=latest
